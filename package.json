{
  "name": "aoiko",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --silent",
    "check": "pnpm run paraglide:compile && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "pnpm run paraglide:compile && vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "pnpm run check && pnpm run test && pnpm run build",
    "xtx:build-schema": "node scripts/build-xtx-schema.js"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.18.2",
    "@inlang/plugin-message-format": "^4.4.0",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.17.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.1",
    "@vitest/ui": "^4.1.8",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "fake-indexeddb": "^6.2.5",
    "fast-xml-parser": "^5.8.0",
    "happy-dom": "^20.9.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-window": "7.4.1"
  },
  "dependencies": {
    "decimal.js": "^10.6.0",
    "dexie": "^4.4.3",
    "tesseract.js": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tesseract.js"
    ]
  }
}