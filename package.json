{
  "name": "aoiko",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --silent",
    "check": "npm run paraglide:compile && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "npm run paraglide:compile && vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run check && npm run test && npm run build",
    "xtx:build-schema": "node scripts/build-xtx-schema.js"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.21.0",
    "@inlang/plugin-message-format": "^4.4.0",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.24.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/encoding-japanese": "^2.2.1",
    "@types/node": "^26.1.1",
    "@vitest/ui": "^4.1.10",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "fake-indexeddb": "^6.2.5",
    "fast-xml-parser": "^5.10.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "shadcn-svelte": "^1.4.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-window": "7.4.1"
  },
  "dependencies": {
    "decimal.js": "^10.6.0",
    "dexie": "^4.4.3",
    "encoding-japanese": "^2.2.0",
    "fflate": "^0.8.3",
    "marked": "^18.0.6",
    "tesseract.js": "^7.0.0"
  }
}
