{
  "name": "aoiko",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libxml2-utils && corepack enable pnpm && pnpm install",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "aoiko (Vite)",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "svelte.svelte-vscode",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer"
      ]
    }
  }
}